<?xml version="1.0" encoding="utf-8"?>
<ApplicationPackage
  SchemaVersion="1.0"
  AutodeskProduct="AutoCAD"
  Name="MyTool"
  Description="MyTool AutoCAD LISP Commands"
  Icon="./Contents/Resources/mytool_icon.bmp"
  AppVersion="1.0.0"
  ProductCode="{12A5F7A4-3E67-46F9-9D91-59BB713C7244}"
  UpgradeCode="{A63EF95D-8BAF-4C90-B233-8C10B6A1D15B}">
  <CompanyDetails Name="MyTool" Url="" />

  <Components Description="LISP command modules">
    <RuntimeRequirements OS="Win64" Platform="AutoCAD*" SupportPath="./Contents/Resources" />

    <ComponentEntry
      AppName="MyToolbar"
      ModuleName="./Contents/Resources/MyToolbar.cuix"
      AppDescription="MyTool custom toolbar"
      LoadOnAutoCADStartup="True" />

    <ComponentEntry
      AppName="mytool_startup.lsp"
      AppType="Lisp"
      ModuleName="./Contents/mytool_startup.lsp"
      AppDescription="Load and show MyToolbar on startup"
      LoadOnAutoCADStartup="True" />

    <ComponentEntry
      AppName="add.lsp"
      AppType="Lisp"
      ModuleName="./Contents/add.lsp"
      AppDescription="ADDNUM command"
      LoadOnAutoCADStartup="True"
      LoadOnCommandInvocation="True">
      <Commands GroupName="ADDNUM">
        <Command Local="ADDNUM" Global="ADDNUM" />
      </Commands>
    </ComponentEntry>

    <ComponentEntry
      AppName="auto_fillet_90.lsp"
      AppType="Lisp"
      ModuleName="./Contents/auto_fillet_90.lsp"
      AppDescription="PL90F/PL90FA commands"
      LoadOnAutoCADStartup="True"
      LoadOnCommandInvocation="True">
      <Commands GroupName="AUTO_FILLET_90">
        <Command Local="PL90F" Global="PL90F" />
        <Command Local="PL90FA" Global="PL90FA" />
      </Commands>
    </ComponentEntry>

    <ComponentEntry
      AppName="datalink_auto.lsp"
      AppType="Lisp"
      ModuleName="./Contents/datalink_auto.lsp"
      AppDescription="Create Data Links for all Excel sheets"
      LoadOnAutoCADStartup="True"
      LoadOnCommandInvocation="True">
      <Commands GroupName="DATALINK_AUTO">
        <Command Local="AUTODATALINKSHEETS" Global="AUTODATALINKSHEETS" />
      </Commands>
    </ComponentEntry>

    <ComponentEntry
      AppName="workstation_auto_connect.lsp"
      AppType="Lisp"
      ModuleName="./Contents/workstation_auto_connect.lsp"
      AppDescription="Workstation auto connection commands"
      LoadOnAutoCADStartup="True"
      LoadOnCommandInvocation="True">
      <Commands GroupName="WORKSTATION_AUTO_CONNECT">
        <Command Local="AUTOWSCONNECTRANGE" Global="AUTOWSCONNECTRANGE" />
      </Commands>
    </ComponentEntry>
  </Components>
</ApplicationPackage>
